{
  "name": "timshermanmusic",
  "version": "0.2.0",
  "description": "Tim Sherman Music — gigs, photos, and booking site",
  "main": "dist/index.html",
  "repository": {
    "url": "git+ssh://git@github.com/WebJamApps/TimShermanMusic.git",
    "type": "git"
  },
  "author": "https://github.com/orgs/WebJamApps/teams/handlersandkickers",
  "engines": {
    "node": "24.18.0"
  },
  "files": [
    "vite.config.ts",
    "src/",
    "public/"
  ],
  "keywords": [
    "React",
    "Typescript",
    "Vite",
    "Vitest"
  ],
  "license": "MIT",
  "scripts": {
    "install:prod": "npm run cleanup && npm install --only=prod",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test:lint": "eslint .",
    "test": "npm run test:lint && npm run typecheck && npm run test:unit",
    "test:unit": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest",
    "test:unit-u": "TZ=UTC vitest run -u",
    "cleanup": "rm -rf yarn.lock && rm -rf package-lock.json && rm -rf node_modules",
    "cleaninstall": "npm install -g npm@latest && npm run cleanup && npm install",
    "smoketest": "npm run cleanup && npm install --omit=dev && npm run build"
  },
  "dependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socketcluster-client": "^20.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/socketcluster-client": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  }
}
